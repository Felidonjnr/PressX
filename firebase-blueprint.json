{
  "entities": {
    "access_request": {
      "title": "Access Request",
      "description": "A request from a user to gain access to the system.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the requester."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the requester."
        },
        "telegram": {
          "type": "string",
          "description": "The Telegram username of the requester (optional)."
        },
        "supportType": {
          "type": "string",
          "enum": ["Web systems", "Media / documents", "Custom solution", "General support"],
          "description": "The type of support requested."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "The status of the request."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the request was submitted."
        }
      },
      "required": ["name", "email", "supportType", "status", "createdAt"]
    }
  },
  "firestore": {
    "/access_requests/{requestId}": {
      "schema": "access_request",
      "description": "Collection of access requests."
    }
  }
}
